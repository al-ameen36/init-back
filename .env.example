GITHUB_TOKEN=gh_

# Tech detection uses the @specfy/stack-analyser bundled into the image
# (tools/analyse.mjs). Override these only if you relocate the binary.
# SPECIFY_NODE=node
# SPECIFY_SCRIPT=/opt/analyser/analyse.mjs

OPENAI_API_KEY=op_
OPENAI_BASE_URL=http://www.example.com
OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct

SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_JWKS_URL=your_supabase_jwks_url

# Memgraph (code-graph persistence). Runs as a separate service/container.
# Point this at a hosted instance to keep the graph DB separate from the API.
MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USER=memgraph
# MEMGRAPH_PASSWORD=

# Comma-separated list of allowed CORS origins. Include your Vercel URL in
# production, e.g. "https://init.vercel.app,http://localhost:3000".
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173