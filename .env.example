GITHUB_TOKEN=gh_

# Tech detection uses the @specfy/stack-analyser bundled into the image
# (tools/analyse.mjs). Override these only if you relocate the binary.
# SPECIFY_NODE=node
# SPECIFY_SCRIPT=/opt/analyser/analyse.mjs

OPENAI_API_KEY=op_
OPENAI_BASE_URL=http://www.example.com
OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct

HF_TOKEN=hf_

SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_JWKS_URL=your_supabase_jwks_url